rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Verifica que el email del usuario autenticado esté en la whitelist
    function isAllowed() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email));
    }

    // allowedUsers: cada usuario solo puede leer su propio documento
    // Escritura bloqueada desde el cliente — solo desde Firebase Console
    match /allowedUsers/{email} {
      allow read:  if request.auth != null && request.auth.token.email == email;
      allow write: if false;
    }

    // Capítulos y anotaciones: solo usuarios en la whitelist
    match /chapters/{doc} {
      allow read, write: if isAllowed();
    }

    match /annotations/{doc} {
      allow read, write: if isAllowed();
    }
  }
}
