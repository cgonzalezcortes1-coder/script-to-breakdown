rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Solo usuarios autenticados (anónimos incluidos) pueden leer/escribir.
    // Esto bloquea cualquier acceso directo a la API sin pasar por el login.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
