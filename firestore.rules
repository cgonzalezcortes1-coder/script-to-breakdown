rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Verifica que el email del usuario autenticado esté en la whitelist
    function isAllowed() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email));
    }

    // Verifica que el usuario sea admin
    function isAdmin() {
      return isAllowed() &&
        get(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email)).data.isAdmin == true;
    }

    // Verifica que el usuario sea miembro del proyecto
    function isProjectMember(projectId) {
      return request.auth.token.email in
        get(/databases/$(database)/documents/projects/$(projectId)).data.members;
    }

    // allowedUsers: cada usuario puede leer su propio doc; admin puede crear nuevos
    match /allowedUsers/{email} {
      allow read:   if request.auth != null && request.auth.token.email == email;
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // Proyectos: admin puede todo; miembros solo lectura
    match /projects/{projectId} {
      allow read: if isAllowed() &&
        (isAdmin() || request.auth.token.email in resource.data.members);
      allow create, update, delete: if isAdmin();
    }

    // Capítulos: admin o miembro del proyecto al que pertenece
    match /chapters/{chapterId} {
      allow read, write: if isAllowed() &&
        (isAdmin() || isProjectMember(resource.data.projectId));
    }

    // Anotaciones: admin o miembro del proyecto al que pertenece
    match /annotations/{annId} {
      allow read, write: if isAllowed() &&
        (isAdmin() || isProjectMember(resource.data.projectId));
    }
  }
}
